def get_items(request):

    items = Item.objects.all()

    results = []

    for item in items:

        results.append(
            {
                "id": item.id,
                "name": item.name,
                "category": item.category,
                "status": item.status,
                "description": item.description,
                "owner": "Unknown",
                "image": item.image.url if item.image else None,
            }
        )

    return JsonResponse({"results": results})


